# Render backend environment variables
# If you set this, backend will look for models/data relative to this path.
# Leave empty to use the repository layout shipped with FraudShield.
MODEL_DIR=
DATA_CSV=

# Optional: control CORS more tightly in production.
# Keep as '*' if you prefer permissive access.
CORS_ALLOW_ORIGINS=

# Optional: set risk threshold override (does not change ML logic)
RISK_FLAG=

